# Homebase reverse proxy. Caddy provisions TLS automatically via Let's Encrypt
# for both domains, as long as their DNS A records point at this box and
# ports 80/443 are open.

{$DOMAIN} {
	reverse_proxy app-prod:3000 {
		# Retry the upstream during the brief window when the app container is
		# being recreated on deploy, so requests don't 502.
		lb_try_duration 30s
		lb_try_interval 1s
	}

	log {
		output stdout
		format json
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}

{$STAGING_DOMAIN} {
	reverse_proxy app-staging:3000 {
		lb_try_duration 30s
		lb_try_interval 1s
	}

	log {
		output stdout
		format json
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
