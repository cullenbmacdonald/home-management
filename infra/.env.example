# Homebase infra environment. Copy to .env on the box (deploy.sh --init does
# this for you and generates the secrets). Values here are read by
# docker-compose.yml for BOTH environments running on this box.

# --- Domains ---------------------------------------------------------------
DOMAIN=homebase.casa
STAGING_DOMAIN=staging.homebase.casa

# --- Postgres (shared instance, two databases) -----------------------------
POSTGRES_USER=homebase
POSTGRES_DB=homebase
# Generated by deploy.sh --init. Keep it secret; changing it later requires
# updating the role password inside Postgres too.
POSTGRES_PASSWORD=changeme

# --- First-boot app accounts (only used when the users table is empty) -----
USER1_USERNAME=cullen
USER1_NAME=Cullen
USER1_PASSWORD=changeme
USER2_USERNAME=madison
USER2_NAME=Madison
USER2_PASSWORD=changeme

# --- App config ------------------------------------------------------------
# Shared secret for the token-cleanup route (/api/cron/oauth-cleanup).
# Leave empty to disable the route (it 404s without it).
CRON_SECRET=

# --- Image tags (managed by deploy.sh — do not edit by hand) ---------------
# Each environment runs an independently-pinned image built on the box.
PROD_IMAGE_TAG=latest
STAGING_IMAGE_TAG=latest
